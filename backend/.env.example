# =============================================================================
# RouteGuard — Environment Variables (PostgreSQL-only / Hackathon mode)
# =============================================================================
# Copy this file to .env and fill in your values.
# The app works with ONLY PostgreSQL — MongoDB and Redis are not required.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=RouteGuard
ENVIRONMENT=development
DEBUG=True

# Change these two secrets before deploying to production!
SECRET_KEY=hackathon-secret-change-in-production-32chars
JWT_SECRET_KEY=hackathon-jwt-secret-change-in-production

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# ── PostgreSQL (REQUIRED) ─────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=routeguard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200   # 30 days

# ── Monitoring ────────────────────────────────────────────────────────────────
MONITORING_INTERVAL_MINUTES=30

# ── External APIs (ALL OPTIONAL — app uses simulated data if empty) ───────────
# Get free tier at: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=

# Get free tier at: https://developer.tomtom.com/
TOMTOM_API_KEY=

# Get at: https://stormglass.io/
STORMGLASS_API_KEY=

# Get at: https://openrouteservice.org/
OPENROUTESERVICE_API_KEY=
