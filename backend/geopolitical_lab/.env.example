# Geopolitical Lab - Environment Template
# This standalone service does not affect your existing RouteGuard backend.

APP_NAME=RouteGuard Geopolitical Lab
DEBUG=true
CORS_ORIGINS=*

# Ingestion controls
INGEST_LIMIT_PER_PROVIDER=20
REQUEST_TIMEOUT_SECONDS=20
LIVE_ZONE_TTL_HOURS=24
DEFAULT_ZONE_RADIUS_KM=200

# Parser mode
PARSER_MODE=rules_structured

# No API keys required for this lab.
